# --- Data Files to Ignore ---
*.csv
*.xls
*.xlsx
*.dat
*.txt

# --- Document Files to Ignore ---
*.pdf
*.docx
*.pptx

# --- System Files (Optional but Recommended) ---
.DS_Store
.Rhistory
.RData

# --- Secrets ---
.env
.env.*

# --- Claude Code local settings (personal, not shared) ---
.claude/settings.local.json

# --- Editor, caches, local-only docs (do not commit) ---
.vscode/
__pycache__/
*.pyc
CLAUDE.md
DATA_ACCESS_POLICY.md


